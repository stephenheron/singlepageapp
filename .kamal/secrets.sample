# Template for .kamal/secrets. Deploying single-page yourself?
#
#     cp .kamal/secrets.sample .kamal/secrets     # real file is gitignored
#     # fill in the values below
#     set -a; source .kamal/secrets; set +a       # load ERB config into your env
#     kamal setup                                  # first deploy
#
# Two kinds of keys live here:
#
#   1. Secret-indirection keys — KAMAL_REGISTRY_* and SINGLEPAGE_APP_TOKEN.
#      Kamal resolves these itself (deploy.yml lists them under `secret:`).
#
#   2. ERB config keys — everything under "Deployment config". deploy.yml reads
#      them with <%= ENV.fetch(...) %>, which only sees the shell env, so you
#      MUST `source` this file (step above) before running kamal.

# --- Registry credentials ---------------------------------------------------
# Container registry login. Provider-specific:
#   DigitalOcean -> both are the same read/write API token
#   Docker Hub   -> your username + an access token
#   GHCR         -> your username + a PAT with write:packages
KAMAL_REGISTRY_USERNAME=your-registry-username
KAMAL_REGISTRY_PASSWORD=your-registry-token

# --- App secret -------------------------------------------------------------
# Admin token for single-page (server + `singlepage` CLI). Generate a random
# one, e.g.  openssl rand -hex 32
SINGLEPAGE_APP_TOKEN=generate-a-random-64-char-hex-string

# --- Deployment config (ERB; must be in the shell env — see header) ---------
# Registry host + image repository path (kamal prepends the host to the image).
#   registry.digitalocean.com | ghcr.io | docker.io | <acct>.dkr.ecr.<region>.amazonaws.com
SINGLEPAGE_REGISTRY_SERVER=registry.digitalocean.com
SINGLEPAGE_IMAGE=your-namespace/single-page

# Target server: public IP/host, SSH user (optional, defaults to root), CPU arch
# (optional, defaults to amd64 — set arm64 for e.g. Graviton/Ampere hosts).
SINGLEPAGE_SERVER_IP=203.0.113.10
# SINGLEPAGE_SERVER_USER=root
# SINGLEPAGE_SERVER_ARCH=amd64

# Your apex domain (sites are served as <site>.BASE_DOMAIN) and the Let's
# Encrypt account email Caddy registers for on-demand certs.
BASE_DOMAIN=example.com
ACME_EMAIL=you@example.com
